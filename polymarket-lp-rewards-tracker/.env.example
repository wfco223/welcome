# ---- Polymarket US Liquidity Rewards Tracker configuration ----
# Copy to `.env` and fill in. All values are optional; without credentials the
# app runs in DEMO mode with synthetic data so you can explore the dashboard.

# Run with synthetic data (no network, no credentials). Auto-enabled when no
# credentials are present. Set to "false" to force live mode.
LPT_DEMO_MODE=true

# Polymarket US API credentials (create at https://polymarket.us/developer).
# Public market/book endpoints work without these; open orders, activities and
# balances require them.
LPT_KEY_ID=
LPT_SECRET_KEY=

# API base URLs (defaults match the official SDK; override only for sandbox).
LPT_GATEWAY_BASE_URL=https://gateway.polymarket.us
LPT_API_BASE_URL=https://api.polymarket.us

# ---- Market Maker / Liquidity Rewards program parameters ----
# The US API does NOT expose these, so they are configured here. Defaults mirror
# Polymarket's published liquidity-rewards model; adjust to the market's actual
# program terms. Per-market overrides live in programs.json (see README).
#
# Minimum resting order size (in shares) to qualify for rewards.
LPT_DEFAULT_MIN_SIZE=100
# Maximum distance from midpoint (in cents) an order may sit and still score.
LPT_DEFAULT_MAX_SPREAD_CENTS=3
# Daily reward pool per market, in USD, split across qualifying makers by score.
LPT_DEFAULT_DAILY_POOL_USD=100

# How many markets to scan for reward opportunities.
LPT_MARKET_SCAN_LIMIT=25

# Dashboard auto-refresh interval (seconds).
LPT_REFRESH_SECONDS=30

# Server bind.
LPT_HOST=127.0.0.1
LPT_PORT=8000
